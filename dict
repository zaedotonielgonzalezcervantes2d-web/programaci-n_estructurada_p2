#ejemplo Crear un programa que solicite los email de los alumnos de la UTD almacenar en una lista y posteriormente mostrar en pantalla los email sin duplicados

#Solucion 1
list_emails=[]
opcion="S"
while opcion=="S":
    email=input("Ingrese email del alumno: ").lower().strip()
    list_emails.append(email)
    opcion=input("¿Desea ingresar otro email? (S/N)").upper().strip()
set_emails=set(list_emails)
list_emails=list(set_emails)
print(list_emails)

#Solucion 2
emails2=[]
while True:
    email=input("Ingrese email del alumno (o 'salir' para terminar): ")
    if email.lower()=='salir':
        break
    emails2.append(email)

print("\nEmails sin duplicados:")
conjunto_emails=set(emails2)
for email in conjunto_emails:
    print(email)
